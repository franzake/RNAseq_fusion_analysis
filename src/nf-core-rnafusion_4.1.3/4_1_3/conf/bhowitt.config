/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bhowitt profile — Howitt Lab, Stanford Sherlock HPC
    Pipeline : nf-core/rnafusion 4.1.3
    Executor : SLURM + Singularity
    Updated  : 2026-06-11
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Usage:
        nextflow run .../main.nf -profile bhowitt --input data/samplesheet.csv -resume

    References, tools, and resource settings are fully specified here.
    Only --input (and optionally --cosmic_username/--cosmic_passwd) are needed at runtime.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// ---------------------------------------------------------------------------
// Pipeline parameters
// ---------------------------------------------------------------------------
params {
    // ── References ───────────────────────────────────────────────────────────
    // All sub-paths resolved automatically via conf/genomes.config using these two keys.
    genomes_base           = '/scratch/users/franzake/RNAseq_fusion_analysis/data/references'
    genome                 = 'GRCh38'
    genome_gencode_version = 46

    // ── Output ───────────────────────────────────────────────────────────────
    outdir                 = '/oak/stanford/groups/bhowitt/rnafusion_results'

    // ── Fusion callers (require ≥2 callers to agree) ─────────────────────────
    tools                  = 'arriba,starfusion,fusioncatcher,fusionreport,fusioninspector'
    tools_cutoff           = 2

    // ── Sequencing (100 bp PE, confirmed for both IM and MT batches) ─────────
    read_length            = 100
    trim_tail              = 0
    trim_tail_fusioncatcher = 0

    // ── COSMIC — use --no_cosmic until credentials are available ─────────────
    // Pass credentials on the command line — never commit them:
    //   --cosmic_username YOUR_EMAIL --cosmic_passwd YOUR_PASSWORD
    no_cosmic              = true
}

// ---------------------------------------------------------------------------
// Container runtime — Singularity only (Docker/Conda disabled on Sherlock)
// ---------------------------------------------------------------------------
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/scratch/users/franzake/singularity_nf_cache'
}
docker.enabled       = false
conda.enabled        = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// ---------------------------------------------------------------------------
// Nextflow work directory (fast scratch — not persistent across quarters)
// ---------------------------------------------------------------------------
workDir = '/scratch/users/franzake/rnafusion_work'

// ---------------------------------------------------------------------------
// SLURM executor
// ---------------------------------------------------------------------------
executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '10/1min'
    jobName         = { task.name.replace(' ', '_') }
}

// ---------------------------------------------------------------------------
// Process resources
// ---------------------------------------------------------------------------
process {
    executor       = 'slurm'
    clusterOptions = '--account=bhowitt'
    queue          = 'owners'          // default: high-throughput owner nodes (2 day limit)

    errorStrategy  = { task.exitStatus in ((130..145) + 104 + (175..177)) ? 'retry' : 'finish' }
    maxRetries     = 2

    resourceLimits = [
        cpus  : 32,
        memory: 256.GB,
        time  : 47.h
    ]

    // ── Label-based resource tiers ────────────────────────────────────────────
    withLabel: process_single {
        cpus   = 2
        memory = { 8.GB   * task.attempt }
        time   = { 4.h    * task.attempt }
    }
    withLabel: process_low {
        cpus   = 4
        memory = { 16.GB  * task.attempt }
        time   = { 4.h    * task.attempt }
    }
    withLabel: process_medium {
        cpus   = 8
        memory = { 48.GB  * task.attempt }
        time   = { 8.h    * task.attempt }
    }
    withLabel: process_high {
        cpus   = 16
        memory = { 80.GB  * task.attempt }
        time   = { 16.h   * task.attempt }
    }
    withLabel: process_long {
        time   = { 24.h   * task.attempt }
    }
    withLabel: process_high_memory {
        // STAR-Fusion and FusionCatcher need >200 GB — route to bigmem nodes
        queue  = 'bigmem'
        cpus   = 16
        memory = { 256.GB * task.attempt }
        time   = { 23.h   * task.attempt }  // bigmem QOS max = 24 h
    }

    // ── Per-tool resource overrides ───────────────────────────────────────────

    // STAR alignment: I/O and CPU heavy; fits on owners
    withName: 'STAR_ALIGN' {
        cpus   = 16
        memory = { 80.GB  * task.attempt }
        time   = { 8.h    * task.attempt }
        queue  = 'owners'
    }

    // STAR-Fusion: CTAT library loads into RAM — must run on bigmem
    withName: 'STARFUSION_DETECT' {
        queue  = 'bigmem'
        cpus   = 16
        memory = { 256.GB * task.attempt }
        time   = { 12.h   * task.attempt }
    }

    // FusionCatcher: genome DB + annotation in RAM — must run on bigmem
    withName: 'FUSIONCATCHER_FUSIONCATCHER' {
        queue  = 'bigmem'
        cpus   = 16
        memory = { 256.GB * task.attempt }
        time   = { 16.h   * task.attempt }
    }

    // Arriba: moderate — uses STAR BAM, no extra alignment step
    withName: 'ARRIBA_ARRIBA' {
        cpus   = 8
        memory = { 32.GB  * task.attempt }
        time   = { 4.h    * task.attempt }
    }

    // FusionInspector: re-alignment step, moderate resources
    withName: 'FUSIONINSPECTOR_INSPECT' {
        cpus   = 8
        memory = { 32.GB  * task.attempt }
        time   = { 8.h    * task.attempt }
    }

    // FusionReport: lightweight DB lookup
    withName: 'FUSIONREPORT_DETECT' {
        cpus   = 2
        memory = { 8.GB   * task.attempt }
        time   = { 2.h    * task.attempt }
    }

    // MultiQC / FastQC: single-threaded, fast
    withName: 'FASTQC' {
        cpus   = 4
        memory = { 8.GB   * task.attempt }
        time   = { 2.h    * task.attempt }
    }
    withName: 'MULTIQC' {
        cpus   = 2
        memory = { 8.GB   * task.attempt }
        time   = { 2.h    * task.attempt }
    }
}
